APP_PORT=

POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# Timezone for scheduled backups
TZ=

# Initial admin username
ADMIN_USERNAME=
# Admin password (empty = passwordless login)
ADMIN_PASSWORD=

# Set to true to mark session cookies as HTTPS-only
SECURE_COOKIES=
# Force local login even when OIDC/SSO is configured
FORCE_LOCAL_LOGIN=